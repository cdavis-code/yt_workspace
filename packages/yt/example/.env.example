# YouTube API Key (for read-only public data access)
# Get one at: https://console.cloud.google.com/apis/credentials
# YT_API_KEY=YOUR_API_KEY_HERE

# OAuth 2.0 Credentials (for authenticated operations)
# Download from Google Cloud Console > API & Services > Credentials
YT_CLIENT_SECRETS_FILE=~/.yt/client_secrets.json

# Access tokens (created by running: yt authorize)
YT_ACCESS_TOKENS_FILE=~/.yt/access_tokens.json
