# yt_mcp Environment Variables Example
#
# Copy this file to .env and fill in your credentials.
# The server reads from .env if environment variables are not set.

# Option 1: API Key (read-only access to public data)
# Get your API key from: https://console.cloud.google.com/apis/credentials
YT_API_KEY=your-api-key-here

# Option 2: OAuth 2.0 (full access - uploads, updates, deletes, live streaming)
# Download client_secrets.json from Google Cloud Console
# Run 'yt authorize' to generate access_tokens.json
YT_CLIENT_SECRETS_FILE=/path/to/client_secrets.json
YT_ACCESS_TOKENS_FILE=/path/to/access_tokens.json

# Note: Use EITHER API key OR OAuth, not both.
# OAuth takes precedence if both are configured.
