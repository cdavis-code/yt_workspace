{
  "name": "@unngh/youtube-api",
  "version": "1.2.0",
  "description": "JavaScript/TypeScript bindings for the yt Dart package. Universal (browser + Node.js) client for YouTube Data and Live Streaming APIs.",
  "license": "MIT",
  "author": "Chris Davis",
  "homepage": "https://github.com/faithoflifedev/yt/tree/main/packages/yt_js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/faithoflifedev/yt.git",
    "directory": "packages/yt_js"
  },
  "bugs": {
    "url": "https://github.com/faithoflifedev/yt/issues"
  },
  "keywords": [
    "youtube",
    "youtube-api",
    "youtube-data-api",
    "streaming",
    "api"
  ],
  "type": "module",
  "main": "./dist/node.cjs",
  "module": "./dist/node.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "browser": "./dist/browser.js",
      "import": "./dist/node.js",
      "require": "./dist/node.cjs",
      "default": "./dist/node.js"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "import": "./dist/browser.js",
      "default": "./dist/browser.js"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "import": "./dist/node.js",
      "require": "./dist/node.cjs",
      "default": "./dist/node.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "happy-dom": "^20.9.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.5"
  },
  "scripts": {
    "build:dart": "bash scripts/build.sh",
    "build:ts": "tsup",
    "build": "npm run build:dart && npm run build:ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf build dist",
    "prepublishOnly": "npm run build"
  }
}
